################################################################################
# GOLDAPP PROJECT - PERFECT GITIGNORE
################################################################################

# 1. Dependencies & Environments
node_modules/
.venv/
env/
venv/
lib/
# package-lock.json  # Note: Standard practice tracks this, but I'll leave it as per your root pattern.

# 2. Environment Variables & Secrets (CRITICAL)
.env
.env.*
!.env.example
secrets.json
credentials.json
*.pem
*.key
*.p12

# 3. Database & Local Data (CRITICAL)
database/*.json
database/backups/
data/
*.db
*.sqlite
dump.rdb

# 4. User Uploads & Media (CRITICAL)
**/uploads/
**/storage/
**/public/uploads/
**/backend/uploads/
**/backend/public/uploads/
!**/uploads/.gitkeep

# 5. Application Logs
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pm2.log
pm2-error.log
pm2-out.log

# 6. Build Outputs & Artifacts
dist/
build/
.next/
out/
.expo/
web-build/
ios/Pods/
ios/build/
ios/DerivedData/
android/app/build/
android/.gradle/
android/local.properties
*.apk
*.ipa
*.app

# 7. OS & System Junk
.DS_Store
Thumbs.db
*.tmp
*.temp
.cache/

# 8. IDE Settings
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

################################################################################
# NOTE: This file only ignores UNTRACKED files. 
# If any of these (like users.json) were already uploaded, use:
# git rm --cached [filename]
