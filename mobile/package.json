{
  "name": "gold-silver-app-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "node start-android.js",
    "android:direct": "expo start --android",
    "android:tunnel": "expo start --android --tunnel",
    "android:no-device": "expo start --android --no-device",
    "fix-adb": "powershell -ExecutionPolicy Bypass -File ./fix-adb.ps1",
    "install-expo-go": "node install-expo-go.js",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "build:android:local": "npx expo prebuild --platform android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "babel-preset-expo": "~54.0.9",
    "expo": "^54.0.0",
    "expo-font": "~14.0.10",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.11.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.2.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.2",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@types/react": "~19.1.10",
    "typescript": "^5.3.3"
  },
  "private": true
}
